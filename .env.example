# Copie este arquivo para .env e preencha os valores

# Banco de dados
# SQLite (para desenvolvimento local - não precisa instalar nada):
DATABASE_URL=sqlite:///./financeiro.db

# PostgreSQL (para produção no Railway/Render):
# DATABASE_URL=postgresql://usuario:senha@host:5432/financeiro_db

# Chave da API da Anthropic (Claude AI)
# Pegue em: https://console.anthropic.com/
ANTHROPIC_API_KEY=sua_chave_aqui

# Evolution API (WhatsApp) - configurar depois
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua_chave_evolution
EVOLUTION_INSTANCE=financeiro-bot
